# -----------------------------------------------------------------------------
# Security note
# -----------------------------------------------------------------------------
# Do NOT list sensitive filenames in this file. The .gitignore itself is
# committed and public. For one-off local files, prefer .git/info/exclude.
# For files that must remain readable by agents, place them under an opaque
# directory (see docs/_private/) and ignore that whole directory with a
# wildcard rule.
# -----------------------------------------------------------------------------

# Local-only Claude settings
.claude/settings.local.json

# Local agent runtime records
.claude/sessions/
.claude/session/
.claude/logs/
.claude/history/
.claude/transcripts/
.codex/
.sessions/
.session/
sessions/
session/
transcripts/
traces/
runs/

# Opaque private directory — agents may read, but filenames are not exposed
docs/_private/**
!docs/_private/
!docs/_private/.gitkeep
!docs/_private/README.md

# User-managed library assets (confidential — see library/README.md)
library/**
!library/
!library/README.md
!library/.gitkeep
!library/house-styles/
!library/house-styles/.gitkeep
!library/templates/
!library/templates/.gitkeep
!library/precedents/
!library/precedents/.gitkeep
!library/inbox/
!library/inbox/.gitkeep
!library/inbox/_audit/
!library/inbox/_audit/.gitkeep
!library/inbox/_processed/
!library/inbox/_processed/.gitkeep
!library/inbox/_failed/
!library/inbox/_failed/.gitkeep
!library/grade-a/
!library/grade-a/.gitkeep
!library/grade-b/
!library/grade-b/.gitkeep
!library/grade-c/
!library/grade-c/.gitkeep

# User-provided input documents (confidential)
input/**
!input/
!input/README.md

# Generated output artifacts (confidential)
output/**
!output/
!output/README.md

# OS/editor noise
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# Local notes and generated records
RELEASE_NOTES.md
CHANGELOG.local.md
*.session
*.session.json
*.transcript
*.trace
*.log
logs/
log/
reports/
test-results/
playwright-report/

# Build and coverage output
build/
dist/
site/
.next/
.vercel/
coverage/
htmlcov/
.coverage
.coverage.*
.nyc_output/

# Temporary runtime files
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp

# Python
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.venv/
venv/
env/

# Node (docx-generator)
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
